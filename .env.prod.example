# ===== Domen =====
# DNS'da bu domen server IP'siga (A-record) yo'naltirilgan bo'lishi shart.
DOMAIN=erp.example.com

# ===== Database =====
POSTGRES_USER=picasso
# Kuchli parol qo'ying:  openssl rand -hex 16
POSTGRES_PASSWORD=BU_YERGA_KUCHLI_PAROL
POSTGRES_DB=picasso

# ===== Backend =====
# Uzun tasodifiy satr:  openssl rand -hex 32
JWT_SECRET=BU_YERGA_UZUN_TASODIFIY_SATR

# Birinchi ishga tushirishda admin foydalanuvchini yaratish uchun true qoldiring.
# Keyin (parolni o'zgartirib) false qilib qayta ishga tushiring.
SEED_ON_START=true
